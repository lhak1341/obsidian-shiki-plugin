{
	"name": "shiki-highlighter",
	"version": "0.7.7",
	"description": "Highlight code blocks with Shiki.",
	"main": "main.js",
	"scripts": {
		"dev": "vite build --mode=development --watch",
		"build": "bun run typecheck && vite build --mode=production",
		"typecheck": "tsc -noEmit -skipLibCheck",
		"test": "bun test",
		"test:log": "LOG_TESTS=true bun test",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "eslint --max-warnings=0 packages/**",
		"lint:fix": "eslint --max-warnings=0 --fix packages/**",
		"check": "bun run format:check && bun run typecheck && bun run lint && bun run test",
		"check:fix": "bun run format && bun run typecheck && bun run lint:fix && bun run test",
		"deploy": "bun run build && mkdir -p \"/Users/lhak/Library/Mobile Documents/iCloud~md~obsidian/Documents/lhakZettel/.obsidian/plugins/shiki-highlighter\" && cp dist/main.js dist/styles.css dist/manifest.json \"/Users/lhak/Library/Mobile Documents/iCloud~md~obsidian/Documents/lhakZettel/.obsidian/plugins/shiki-highlighter/\"",
		"release": "lemons-automation release"
	},
	"keywords": [],
	"author": "Moritz Jung",
	"license": "MIT",
	"overrides": {
		"@codemirror/state": "^6.7.0",
		"@codemirror/view": "^6.43.2"
	},
	"resolutions": {
		"@codemirror/state": "^6.7.0",
		"@codemirror/view": "^6.43.2"
	},
	"devDependencies": {
		"@codemirror/language": "^6.12.3",
		"@codemirror/state": "^6.7.0",
		"@codemirror/view": "^6.43.2",
		"@eslint/js": "^10.0.1",
		"@expressive-code/core": "^0.43.1",
		"@expressive-code/plugin-collapsible-sections": "^0.43.1",
		"@expressive-code/plugin-frames": "^0.43.1",
		"@expressive-code/plugin-line-numbers": "^0.43.1",
		"@expressive-code/plugin-shiki": "^0.43.1",
		"@expressive-code/plugin-text-markers": "^0.43.1",
		"@happy-dom/global-registrator": "^20.10.6",
		"@lemons_dev/lemons-obsidian-plugin-automation": "^0.1.4",
		"@lezer/common": "^1.5.2",
		"@tsconfig/svelte": "^5.0.8",
		"@types/bun": "^1.3.14",
		"@types/prismjs": "^1.26.6",
		"eslint-plugin-import-x": "^4.17.0",
		"eslint-plugin-no-relative-import-paths": "^1.6.1",
		"eslint-plugin-only-warn": "^1.2.1",
		"hast-util-to-dom": "^4.0.1",
		"itertools-ts": "^2.5.0",
		"obsidian": "^1.13.1",
		"prettier": "^3.8.4",
		"shiki": "^4.2.0",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.0",
		"vite": "^8.1.0",
		"vite-plugin-banner": "^0.8.1",
		"vite-plugin-node-polyfills": "^0.28.0",
		"vite-plugin-static-copy": "^4.1.1"
	}
}
